# ---- SQL Server (read-only) ----
# Completar con los valores reales en .env (este archivo es solo un template).
DB_SERVER=192.168.X.X
DB_INSTANCE=NOMBRE_INSTANCIA
DB_PORT=1433
DB_NAME=NombreBaseDatos
DB_USER=usuario_solo_lectura
DB_PASSWORD=cambiar_esta_clave

# Tabla de datos de Producción (datos horarios de pozos/puntos)
PROD_TABLE=Horarios_Oil
PROD_SCHEMA=dbo

# ---- Backend ----
PORT=4000

# ---- Auth ----
# AUTH_ENABLED=false durante desarrollo para no pelear con el login.
# En producción: true.
AUTH_ENABLED=false
JWT_SECRET=poner_una_clave_larga_y_secreta
# Credencial compartida temporal (reemplazar por LDAP/AD en fase 3)
PORTAL_USER=consulta
PORTAL_PASSWORD=cambiar_esta_clave
